# API Configuration
# Uncomment and set this for production API integration
# VITE_API_URL=https://api.sparkleclean.pro

# Site Configuration
VITE_SITE_URL=https://sparkleclean.pro

# Supabase (Required for quote persistence)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Functions (for email notifications)
# Set this to your Supabase project URL
VITE_SUPABASE_FUNCTIONS_URL=https://your-project.functions.supabase.co

# Email Notifications (Resend API)
# ⚠️ DO NOT set in frontend .env — configure as Supabase Edge Function secret
# Run: supabase secrets set RESEND_API_KEY=re_xxx
# Or set in Supabase Dashboard > Project Settings > Edge Functions > Secrets

# Feature flags
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_SENTRY=true
# VITE_SENTRY_DSN=

# Analytics (Plausible — privacy-first, no cookies)
# VITE_PLAUSIBLE_DOMAIN=sparkleclean.pro
