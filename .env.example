# API Configuration
# Uncomment and set this for production API integration
# VITE_API_URL=https://api.sparkleclean.pro

# Supabase (Required for quote persistence)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Email Notifications (Resend API)
# Configure as Supabase Edge Function secret, NOT in frontend env
# RESEND_API_KEY=re_your-key  (set via: supabase secrets set RESEND_API_KEY=re_xxx)

# Feature flags
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_SENTRY=true
# VITE_SENTRY_DSN=

# Analytics (Plausible — privacy-first, no cookies)
# VITE_PLAUSIBLE_DOMAIN=sparkleclean.pro
