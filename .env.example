# API Configuration
# Uncomment and set this for production API integration
# VITE_API_URL=https://api.sparkleclean.pro

# Site Configuration
VITE_SITE_URL=https://sparkleclean.pro

# Supabase (Required for quote persistence)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Functions (for email notifications, payments, admin)
VITE_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

# Stripe Payments
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Email Notifications (Resend API)
# ⚠️ DO NOT set in frontend .env — configure as Supabase Edge Function secret
# Run: supabase secrets set RESEND_API_KEY=re_xxx STRIPE_SECRET_KEY=sk_xxx STRIPE_WEBHOOK_SECRET=whsec_xxx ADMIN_LOGIN_PIN=123456 FRONTEND_URL=https://sparkleclean.pro

# Feature flags
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_SENTRY=true
# VITE_SENTRY_DSN=

# Analytics (Plausible — privacy-first, no cookies)
# VITE_PLAUSIBLE_DOMAIN=sparkleclean.pro
